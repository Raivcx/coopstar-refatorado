# .env.example - exemplo de variáveis de ambiente
# Copie este arquivo para .env e ajuste os valores antes de iniciar a aplicação

# Porta do servidor local (padrão 3000)
PORT=3000

# URL base da API (se houver)
API_BASE_URL=https://api.exemplo.com

# Chave de API (não commitada)
# API_KEY=seu_token_aqui
